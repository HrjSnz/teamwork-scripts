{
  "name": "teamwork-time-export",
  "version": "0.1.0",
  "description": "Simple CLI pro stažení výkazu času z Teamwork API",
  "type": "module",
  "bin": {
    "fetch-time": "bin/fetch-time.ts",
    "check-overlaps": "bin/check-overlaps.ts",
    "fetch-and-check": "bin/fetch-and-check.ts"
  },
  "scripts": {
    "fetch": "node bin/fetch-time.ts",
