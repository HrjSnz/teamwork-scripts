# Copy to .env and fill in your values:  cp .env.example .env

# Your Teamwork account subdomain (from URL https://mycompany.teamwork.com).
# You can enter just "mycompany" or the full host "mycompany.teamwork.com".
TEAMWORK_DOMAIN=mycompany

# Your API key:
# Teamwork → click your avatar → Edit My Details → "API & Mobile" tab → API Token
TEAMWORK_API_KEY=your_api_key
